{
  "name": "editimages",
  "compatibility_date": "2026-07-01",
  "pages_build_output_dir": "out",
  "vars": { "AUTH_MODE": "disabled", "PAYMENT_PROVIDER": "stripe" },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "editimages-feedback-db",
      "database_id": "0c3b38e2-6cd0-40bd-8b5c-d603b106a035",
      "migrations_dir": "./migrations"
    }
  ],
  "services": [
    { "binding": "BILLING", "service": "bestmcp-billing" }
  ]
}
